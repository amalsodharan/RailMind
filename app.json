{
  "expo": {
    "name": "RailMind",
    "slug": "railmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1565C0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.railwayreminder"
    },
    "android": {
      "package": "com.yourname.railwayreminder",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1565C0"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#1565C0",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1322ead0-9f99-40f7-bdc1-12a203da44ad"
      }
    }
  }
}